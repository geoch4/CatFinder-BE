{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "CatFinderDb": "Server=(localdb)\\mssqllocaldb;Database=CatFinder;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },

  "CorsOrigins": [
    "http://localhost:5173",
    "http://localhost:3000"
  ],

  "Jwt": {
    "Key": "catfinder-development-secret-key-123456789",
    "Issuer": "CatFinder",
    "Audience": "CatFinderUsers"
  },

  "OpenAI": {
    "ApiKey": ""
  },

  "JwtSettings": {
    "SecretKey": "catfinder-development-secret-key-123456789",
    "Issuer": "CatFinderAPI",
    "Audience": "CatFinderClient",
    "ExpiresInMinutes": 60,
    "RefreshTokenExpiresInDays": 7
  }

}